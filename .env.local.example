# Sumsub API Configuration
# Get these from your Sumsub dashboard: https://cockpit.sumsub.com
SUMSUB_APP_TOKEN=your_app_token_here
SUMSUB_SECRET_KEY=your_secret_key_here
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database
DATABASE_PATH=./data/kyc.db

# User Session (simple UUID-based for Stage 1 - no auth)
# In production, replace with proper auth (NextAuth, Clerk, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000