# Sumsub API Configuration
# Get these from your Sumsub dashboard: https://cockpit.sumsub.com
SUMSUB_APP_TOKEN=your_app_token_here
SUMSUB_SECRET_KEY=your_secret_key_here
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database
DATABASE_PATH=./data/kyc.db

NEXT_PUBLIC_APP_URL=http://localhost:3004

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Seed credentials for first admin and default agent (used by migrate-v2.js)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_me
SEED_ADMIN_NAME=System Admin
SEED_AGENT_USERNAME=agent1
SEED_AGENT_PASSWORD=change_me
SEED_AGENT_NAME=Default Agent
SEED_AGENT_SUBDOMAIN=agent1
SEED_AGENT_EMAIL=agent1@example.com