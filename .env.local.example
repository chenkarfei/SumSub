# Sumsub API credentials
SUMSUB_APP_TOKEN=your_sumsub_app_token_here
SUMSUB_SECRET_KEY=your_sumsub_secret_key_here
SUMSUB_WEBHOOK_SECRET=your_sumsub_webhook_secret_here

# JWT signing secret (generate a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Server port (default: 3004)
PORT=3004

# Sumsub level name (from your Sumsub account)
SUMSUB_LEVEL_NAME=id-and-liveness

# Initial admin credentials (only used by init-db script)
ADMIN_USERNAME=admin
ADMIN_NAME=Administrator
ADMIN_PASSWORD=changeme123
